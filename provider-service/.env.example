# hyscode-gateway — Variáveis de ambiente

# Banco de dados PostgreSQL
DATABASE_URL=postgres://hyscode:secret@localhost:5432/hyscode_gateway

# Redis
REDIS_URL=redis://localhost:6379

# Endereço de escuta
LISTEN_ADDR=0.0.0.0:3000

# Segredo JWT (gere com: openssl rand -hex 64)
JWT_SECRET=change_me_to_random_64_byte_hex

# Mapeamento de modelos → provedores
# Formato: alias=provider,alias2=provider2
MODEL_ROUTES=claude-3-5-sonnet=anthropic,claude-3-5-haiku=anthropic,gpt-4o=openai,gpt-4o-mini=openai

# API keys dos provedores upstream
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Nível de log
LOG_LEVEL=info
